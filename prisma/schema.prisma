generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String?
  image             String?
  role              String    @default("USER")
  referralCode      String    @unique
  referredBy        String?
  discountBalance   Float     @default(0)
  stripeCustomerId  String?   @unique
  credits           Int       @default(0)
  resetToken              String?   @unique
  resetTokenExpiry        DateTime?
  emailVerified           Boolean   @default(false)
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?
  isStudent               Boolean   @default(false)
  workerApproved          Boolean   @default(true)   // set to false on worker self-registration; admin flips to true

  // Profile data
  phone             String?
  cedula            String?
  birthDate         DateTime?

  // Seller referral: populated when this user was referred by a SELLER
  referredBySellerId String?
  referredBySeller   User?           @relation("SellerClients", fields: [referredBySellerId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  subscription      Subscription?
  referralsGiven    Referral[]      @relation("Referrer")
  referralsReceived Referral[]      @relation("Referred")
  contacts          Contact[]
  creditPurchases   CreditPurchase[]
  printJobs         PrintJob[]      @relation("ClientJobs")
  workerJobs        PrintJob[]      @relation("WorkerJobs")
  workerProfile     WorkerProfile?
  addresses         UserAddress[]
  chatMessages      ChatMessage[]
  notifications     Notification[]
  sellerClients     User[]          @relation("SellerClients")
  sellerCommissions SellerCommission[]
}

model UserAddress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   // e.g. "Casa", "Oficina"
  recipientName String
  phone         String
  street        String
  sector        String
  city          String
  province      String
  notes         String?
  isDefault     Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender      String   // 'USER' | 'ADMIN'
  content     String
  readByUser  Boolean  @default(false)
  readByAdmin Boolean  @default(false)

  createdAt   DateTime @default(now())
}

model WorkerProfile {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive      Boolean          @default(true)
  completedJobs Int              @default(0)

  // Contract acceptance record
  contractAccepted   Boolean   @default(false)
  contractAcceptedAt DateTime?
  contractAcceptedIp String?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  machines      PrinterMachine[]
}

model PrinterMachine {
  id                 String        @id @default(cuid())
  workerProfileId    String
  workerProfile      WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  machineType        String        @default("printer_3d") // printer_3d | resin | laser
  supportedColors    String        // JSON array
  supportedFilaments String        // JSON array
  supportedNozzles   String        // JSON array
  laserType          String?       // CO2 | Plasma (laser only)
  dimensions         String?       // equipment dimensions (laser only)
  isActive           Boolean       @default(true)
  completedJobs      Int           @default(0)
  octoprintUrl       String?
  octoprintApiKey    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  printJobs          PrintJob[]    @relation("MachineJobs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId  String?  @unique
  stripePriceId        String?
  plan                 String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  paypalOrderId        String?
  paymentProofUrl      String?
  paymentMethod        String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String
  reward         Float    @default(0)
  used           Boolean  @default(false)

  createdAt      DateTime @default(now())

  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referredUser User     @relation("Referred", fields: [referredUserId], references: [id])

  @@unique([referrerId, referredUserId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CreditPurchase {
  id               String   @id @default(cuid())
  userId           String
  credits          Int
  amount           Float
  paymentId        String?
  status           String   @default("pending")
  paymentProofUrl  String?
  paymentMethod    String?

  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrintJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("ClientJobs", fields: [userId], references: [id], onDelete: Cascade)

  fileName        String
  fileUrl         String
  fileSize        Float?
  creditsCost     Int       @default(0)
  status          String    @default("pending")
  notes           String?
  creditsDeducted Boolean   @default(false)

  // Service type
  serviceType      String    @default("print_3d")

  // Client print specifications
  color           String?
  filamentType    String?
  deliveryTime    String    @default("standard")

  // 3D print extras
  scale           String?
  realSize        String?

  // Laser cutting/engraving
  laserCutColor   String?
  laserEngravColor String?

  // Resin
  resinColor      String?
  resinUse        String?

  // Design service
  designDescription   String?
  designMeasures      String?
  designReferenceUrls String?
  designMaterial      String?
  designUse           String?   // decorative | mechanical
  designIsVehicle     Boolean?  @default(false)
  designVehicleMake   String?
  designVehicleModel  String?
  designVehicleYear   String?
  referenceImageUrls  String?   // JSON array of uploaded reference image URLs

  // Designer payment (set manually by admin)
  designerEarnings    Float?
  designerPaid        Boolean   @default(false)
  designerPaidAt      DateTime?

  // Maker payment (auto-calculated: creditsCost × 10 RD$)
  makerPaid           Boolean   @default(false)
  makerPaidAt         DateTime?

  // Delivery
  deliveryType      String?   // 'pickup' | 'delivery'
  deliveryAddress   String?   // JSON snapshot of the selected address
  trackingUrl       String?   // Link to track the delivery (Uber/InDrive/DIDI)

  // Live camera feed
  cameraUrl         String?

  // Proof of work & rating
  completionPhotoUrl String?
  completedAt        DateTime?
  rating             Int?
  ratingComment      String?
  ratedAt            DateTime?

  // Quality Management System
  qmsStage           String?   // file_validation | print_setup | in_production | post_processing | quality_check | ready | delivered | redo
  deliveredAt        DateTime?

  qualityInspection  QualityInspection?
  qualityPhotos      QualityPhoto[]
  productionLogs     ProductionLog[]

  // Maker feedback
  makerFeedback     String?   // JSON: { issues[], notes, suggestion }

  // Auto-quote (from STL parser + pricing engine)
  quoteVolumeCm3    Float?
  quoteBboxX        Float?
  quoteBboxY        Float?
  quoteBboxZ        Float?
  quotedPrice       Float?
  quotedAt          DateTime?
  autoQuoted        Boolean   @default(false)
  infill            Int?      // percentage: 15, 20, 30, 50, 100
  qualityLevel      String?   // draft | standard | fine

  // Pricing & Payment
  price             Float?
  priceStatus       String    @default("unpaid")
  appealNote        String?
  paymentProofUrl   String?
  paymentMethod     String?
  paymentNotes      String?
  paidAt            DateTime?

  // Worker assignment
  assignedWorkerId  String?
  assignedWorker    User?           @relation("WorkerJobs", fields: [assignedWorkerId], references: [id])
  assignedMachineId String?
  assignedMachine   PrinterMachine? @relation("MachineJobs", fields: [assignedMachineId], references: [id])
  assignedAt        DateTime?
  acceptedAt        DateTime?
  startedAt         DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model QualityInspection {
  id              String   @id @default(cuid())
  printJobId      String   @unique
  printJob        PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  fileValidation  String?
  printSetup      String?
  productionData  String?
  postProcessing  String?
  qualityScore    String?
  initiatedBy     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QualityPhoto {
  id          String   @id @default(cuid())
  printJobId  String
  printJob    PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  category    String
  fileUrl     String
  caption     String?
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model ProductionLog {
  id          String   @id @default(cuid())
  printJobId  String
  printJob    PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  stage       String
  action      String
  fromStage   String?
  toStage     String?
  userId      String
  userName    String
  comment     String?
  metadata    String?
  createdAt   DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  time        String
  location    String
  type        String
  imageUrl    String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id           String         @id @default(cuid())
  title        String
  description  String
  price        Float          @default(0)
  isFree       Boolean        @default(false)
  isIntro      Boolean        @default(false)
  category     String?
  thumbnailUrl String?
  published    Boolean        @default(false)
  lessons      CourseLesson[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model CourseLesson {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  videoUrl  String?
  duration  String?
  order     Int      @default(0)
  isFree    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PricingConfig {
  id                     Int      @id @default(1)
  // JSON: { PLA: 1.24, 'PLA+': 1.24, PETG: 1.27, ABS: 1.05, 'TPU (Flexible)': 1.21, ASA: 1.07, Nylon: 1.14, 'SILK PLA': 1.24, 'WOOD PLA': 1.15, 'Resina (SLA)': 1.18 }
  materialDensity        String
  // JSON: { PLA: 0.40, 'PLA+': 0.45, PETG: 0.50, ABS: 0.48, 'TPU (Flexible)': 0.65, ASA: 0.55, Nylon: 0.70, 'SILK PLA': 0.50, 'WOOD PLA': 0.45, 'Resina (SLA)': 0.90 } RD$/gram
  materialPricePerGram   String
  // JSON: { PLA: 30, 'PLA+': 30, ... } margin percentage per material (overrides platformMargin)
  materialMarginPercent  String   @default("{}")
  // JSON: { PLA: 400, ... } RD$ cost per roll
  materialRollCost       String   @default("{}")
  // JSON: { PLA: 1000, ... } grams per roll
  materialRollWeightG    String   @default("{}")
  machineRatePerHour     Float    @default(100)   // RD$/hour
  platformMargin         Float    @default(0.30)  // 30%
  makerSplit             Float    @default(0.70)  // 70% of base cost to maker
  // JSON: { draft: 25, standard: 15, fine: 8 } grams/hour extrusion rate
  extrusionRateByQuality String
  updatedAt              DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SellerCommission {
  id          String    @id @default(cuid())
  sellerId    String
  seller      User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  clientId    String?   // the referred user who paid (null for bonus)
  printJobId  String?   // the job that triggered the commission (null for bonus)
  type        String    // 'first_service' | 'recurring' | 'bonus'
  rate        Float     @default(0)   // 0.10, 0.03, or 0 for bonus
  jobPrice    Float     @default(0)   // job price at calculation time (0 for bonus)
  amount      Float                   // RD$ commission amount
  status      String    @default("pending") // 'pending' | 'paid'
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
}
