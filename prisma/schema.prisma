generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String?
  image             String?
  role              String    @default("USER")
  referralCode      String    @unique
  referredBy        String?
  discountBalance   Float     @default(0)
  stripeCustomerId  String?   @unique
  credits           Int       @default(0)
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  subscription      Subscription?
  referralsGiven    Referral[]      @relation("Referrer")
  referralsReceived Referral[]      @relation("Referred")
  contacts          Contact[]
  creditPurchases   CreditPurchase[]
  printJobs         PrintJob[]      @relation("ClientJobs")
  workerJobs        PrintJob[]      @relation("WorkerJobs")
  workerProfile     WorkerProfile?
}

model WorkerProfile {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive      Boolean          @default(true)
  completedJobs Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  machines      PrinterMachine[]
}

model PrinterMachine {
  id                 String        @id @default(cuid())
  workerProfileId    String
  workerProfile      WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  supportedColors    String        // JSON array
  supportedFilaments String        // JSON array
  supportedNozzles   String        // JSON array
  isActive           Boolean       @default(true)
  completedJobs      Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  printJobs          PrintJob[]    @relation("MachineJobs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId  String?  @unique
  stripePriceId        String?
  plan                 String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  paypalOrderId        String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String
  reward         Float    @default(0)
  used           Boolean  @default(false)

  createdAt      DateTime @default(now())

  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referredUser User     @relation("Referred", fields: [referredUserId], references: [id])

  @@unique([referrerId, referredUserId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CreditPurchase {
  id            String   @id @default(cuid())
  userId        String
  credits       Int
  amount        Float
  paymentId     String?
  status        String   @default("pending")

  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrintJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("ClientJobs", fields: [userId], references: [id], onDelete: Cascade)

  fileName        String
  fileUrl         String
  fileSize        Float?
  creditsCost     Int       @default(0)
  status          String    @default("pending")
  notes           String?
  creditsDeducted Boolean   @default(false)

  // Service type
  serviceType      String    @default("print_3d")

  // Client print specifications
  color           String?
  filamentType    String?
  deliveryTime    String    @default("standard")

  // 3D print extras
  scale           String?
  realSize        String?

  // Laser cutting/engraving
  laserCutColor   String?
  laserEngravColor String?

  // Resin
  resinColor      String?
  resinUse        String?

  // Maker feedback
  makerFeedback     String?   // JSON: { issues[], notes, suggestion }

  // Worker assignment
  assignedWorkerId  String?
  assignedWorker    User?           @relation("WorkerJobs", fields: [assignedWorkerId], references: [id])
  assignedMachineId String?
  assignedMachine   PrinterMachine? @relation("MachineJobs", fields: [assignedMachineId], references: [id])
  assignedAt        DateTime?
  acceptedAt        DateTime?
  startedAt         DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
